# Include documentation files
include README.md
include LICENSE
include CHANGELOG.md
include VERSION

# Include templates directory recursively (root-level, not in packages)
# These are used by the CLI for generating new items, configs, etc.
recursive-include templates *.md *.json *.toml *.template

# Include schema files (SQL files for database initialization)
# Already covered by package_data, but explicit inclusion ensures they're in sdist
recursive-include src/python/kano_backlog_core/schema *.sql

# Include PEP 561 type marker files
# These indicate that packages support type checking
include src/python/kano_backlog_core/py.typed
include src/python/kano_backlog_ops/py.typed
include src/python/kano_backlog_cli/py.typed

# Include packaged CLI templates used by installed commands
recursive-include src/python/kano_backlog_cli/templates *.toml

# Include type stub files for sentence_transformers
include src/python/sentence_transformers/__init__.pyi

# Exclude repository tests from release artifacts; package-data includes above are explicit.
recursive-exclude tests *
