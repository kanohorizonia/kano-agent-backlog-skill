{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentskill-backlog.kanohorizonia.com/references/release-notes-evidence-bundle.schema.json",
  "title": "KOB Release Notes Evidence Bundle",
  "type": "object",
  "required": [
    "schema",
    "release_id",
    "version_label",
    "product",
    "source_inputs",
    "missing_evidence",
    "draft_release_notes",
    "human_verification",
    "publication_boundary"
  ],
  "properties": {
    "schema": { "const": "kob.release.notes.evidence_bundle.v1" },
    "release_id": { "$ref": "#/$defs/non_empty_string" },
    "version_label": { "$ref": "#/$defs/non_empty_string" },
    "product": { "$ref": "#/$defs/non_empty_string" },
    "source_inputs": { "$ref": "#/$defs/source_inputs" },
    "missing_evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/missing_evidence" }
    },
    "draft_release_notes": { "$ref": "#/$defs/draft_release_notes" },
    "human_verification": { "$ref": "#/$defs/human_verification" },
    "publication_boundary": { "$ref": "#/$defs/publication_boundary" }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "repo_relpath": {
      "type": "string",
      "pattern": "^(?![A-Za-z]:)(?!/)(?!\\\\)(?!.*\\.\\.)([A-Za-z0-9._-]+/)*[A-Za-z0-9._-]+/?$"
    },
    "bounded_ref": {
      "type": "object",
      "required": ["product"],
      "properties": {
        "product": { "$ref": "#/$defs/non_empty_string" },
        "item_id": { "$ref": "#/$defs/non_empty_string" },
        "uid": { "$ref": "#/$defs/non_empty_string" },
        "commit_sha": { "type": "string", "pattern": "^[0-9a-fA-F]{7,40}$" },
        "evidence_id": { "$ref": "#/$defs/non_empty_string" },
        "artifact_id": { "$ref": "#/$defs/non_empty_string" },
        "doc_id": { "$ref": "#/$defs/non_empty_string" },
        "release_id": { "$ref": "#/$defs/non_empty_string" },
        "repo_relpath": { "$ref": "#/$defs/repo_relpath" },
        "reason": { "$ref": "#/$defs/non_empty_string" }
      },
      "anyOf": [
        { "required": ["item_id"] },
        { "required": ["uid"] },
        { "required": ["commit_sha"] },
        { "required": ["evidence_id"] },
        { "required": ["artifact_id"] },
        { "required": ["doc_id"] },
        { "required": ["release_id"] },
        { "required": ["repo_relpath"] }
      ],
      "additionalProperties": false
    },
    "source_inputs": {
      "type": "object",
      "required": [
        "included_items",
        "commit_refs",
        "validation_refs",
        "dogfood_refs",
        "limitations",
        "public_docs_targets"
      ],
      "properties": {
        "included_items": {
          "type": "array",
          "items": { "$ref": "#/$defs/bounded_ref" }
        },
        "commit_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/bounded_ref" }
        },
        "validation_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/bounded_ref" }
        },
        "dogfood_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/bounded_ref" }
        },
        "limitations": {
          "type": "array",
          "items": { "$ref": "#/$defs/limitation" }
        },
        "public_docs_targets": {
          "type": "array",
          "items": { "$ref": "#/$defs/public_docs_target" }
        }
      },
      "additionalProperties": false
    },
    "limitation": {
      "type": "object",
      "required": ["summary", "source_refs"],
      "properties": {
        "summary": { "$ref": "#/$defs/non_empty_string" },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/bounded_ref" }
        },
        "release_note_instruction": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "public_docs_target": {
      "type": "object",
      "required": ["doc_id", "publication_state", "reason"],
      "properties": {
        "doc_id": { "$ref": "#/$defs/non_empty_string" },
        "channel_id": { "$ref": "#/$defs/non_empty_string" },
        "repo_relpath": { "$ref": "#/$defs/repo_relpath" },
        "publication_state": {
          "enum": ["planned", "draft", "ready_for_review", "approved_for_publication"]
        },
        "reason": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "missing_evidence": {
      "type": "object",
      "required": ["evidence_id", "claim", "required_source", "reason"],
      "properties": {
        "evidence_id": { "$ref": "#/$defs/non_empty_string" },
        "claim": { "$ref": "#/$defs/non_empty_string" },
        "required_source": { "$ref": "#/$defs/non_empty_string" },
        "reason": { "$ref": "#/$defs/non_empty_string" },
        "owner_or_follow_up": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "draft_release_notes": {
      "type": "object",
      "required": ["artifact_id", "repo_relpath", "generation_boundary", "sections"],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/non_empty_string" },
        "repo_relpath": { "$ref": "#/$defs/repo_relpath" },
        "generation_boundary": { "$ref": "#/$defs/non_empty_string" },
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/draft_section" }
        }
      },
      "additionalProperties": false
    },
    "draft_section": {
      "type": "object",
      "required": ["section_id", "title", "status", "body"],
      "properties": {
        "section_id": { "$ref": "#/$defs/non_empty_string" },
        "title": { "$ref": "#/$defs/non_empty_string" },
        "status": { "enum": ["draft", "supported", "omitted_missing_evidence", "needs_human_review"] },
        "body": { "$ref": "#/$defs/non_empty_string" },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/bounded_ref" }
        },
        "missing_evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      },
      "anyOf": [
        { "required": ["source_refs"] },
        { "required": ["missing_evidence_refs"] }
      ],
      "additionalProperties": false
    },
    "human_verification": {
      "type": "object",
      "required": ["status", "required_before_publication", "markers"],
      "properties": {
        "status": { "enum": ["not_started", "in_review", "verified_internal", "approved_for_publication", "rejected"] },
        "required_before_publication": { "const": true },
        "markers": {
          "type": "array",
          "items": { "$ref": "#/$defs/verification_marker" }
        },
        "review_summary": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "verification_marker": {
      "type": "object",
      "required": ["marker_id", "marker_type", "status", "reason"],
      "properties": {
        "marker_id": { "$ref": "#/$defs/non_empty_string" },
        "marker_type": { "enum": ["source_review", "evidence_review", "notes_review", "publication_review"] },
        "status": { "enum": ["pending", "passed", "rejected"] },
        "verification_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/bounded_ref" }
        },
        "reason": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    },
    "publication_boundary": {
      "type": "object",
      "required": ["live_publication_claimed", "handoff_owner", "public_output_refs"],
      "properties": {
        "live_publication_claimed": { "const": false },
        "handoff_owner": { "const": "KOB-TSK-0093" },
        "public_output_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/public_docs_target" }
        },
        "reason": { "$ref": "#/$defs/non_empty_string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
