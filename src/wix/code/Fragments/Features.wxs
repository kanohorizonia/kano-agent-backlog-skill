<Include xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <?ifndef HasAssets ?>
  <?define HasAssets = 0 ?>
  <?endif?>
  <?ifndef HasDocs ?>
  <?define HasDocs = 0 ?>
  <?endif?>
  <?ifndef HasExamples ?>
  <?define HasExamples = 0 ?>
  <?endif?>
  <?ifndef HasProfiles ?>
  <?define HasProfiles = 0 ?>
  <?endif?>
  <?ifndef HasReferences ?>
  <?define HasReferences = 0 ?>
  <?endif?>
  <?ifndef HasSrcShell ?>
  <?define HasSrcShell = 0 ?>
  <?endif?>
  <?ifndef HasTemplates ?>
  <?define HasTemplates = 0 ?>
  <?endif?>
  <?ifndef HasTypings ?>
  <?define HasTypings = 0 ?>
  <?endif?>

  <Fragment>
    <Feature
      Id="CoreFiles"
      Title="Core files"
      Description="Installs kano-agent-backlog-skill files and the compiled backlog CLI."
      Level="1"
      AllowAbsent="no"
      AllowAdvertise="no">
      <ComponentGroupRef Id="CoreRootComponents" />
      <ComponentGroupRef Id="CoreBinComponents" />
      <ComponentGroupRef Id="CoreScriptsComponents" />
      <?if $(var.HasAssets) = 1 ?>
      <ComponentGroupRef Id="CoreAssetsComponents" />
      <?endif?>
      <?if $(var.HasDocs) = 1 ?>
      <ComponentGroupRef Id="CoreDocsComponents" />
      <?endif?>
      <?if $(var.HasExamples) = 1 ?>
      <ComponentGroupRef Id="CoreExamplesComponents" />
      <?endif?>
      <?if $(var.HasProfiles) = 1 ?>
      <ComponentGroupRef Id="CoreProfilesComponents" />
      <?endif?>
      <?if $(var.HasReferences) = 1 ?>
      <ComponentGroupRef Id="CoreReferencesComponents" />
      <?endif?>
      <?if $(var.HasSrcShell) = 1 ?>
      <ComponentGroupRef Id="CoreSrcShellComponents" />
      <?endif?>
      <?if $(var.HasTemplates) = 1 ?>
      <ComponentGroupRef Id="CoreTemplatesComponents" />
      <?endif?>
      <?if $(var.HasTypings) = 1 ?>
      <ComponentGroupRef Id="CoreTypingsComponents" />
      <?endif?>
    </Feature>

    <Feature
      Id="ShellIntegration"
      Title="Shell integration"
      Description="Adds the installed scripts directory to the per-user PATH."
      Level="1"
      AllowAdvertise="no">
      <ComponentGroupRef Id="ShellIntegrationComponents" />
    </Feature>
  </Fragment>
</Include>
