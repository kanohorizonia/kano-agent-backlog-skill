#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILL_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
EXPECTED_VERSION="$(tr -d '\r\n' < "$SKILL_ROOT/VERSION")"

find_python_bin() {
  local candidate
  for candidate in \
    python \
    python3 \
    py \
    "$SKILL_ROOT/.venv/Scripts/python.exe" \
    "$SKILL_ROOT/.venv/bin/python" \
    "$HOME/.pixi/bin/python"
  do
    if command -v "$candidate" >/dev/null 2>&1; then
      printf '%s\n' "$candidate"
      return 0
    fi
    if [[ -x "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

resolve_workspace_root() {
  local start_dir="${PWD}"
  while [[ "$start_dir" != "/" && ! -f "$start_dir/.kano/backlog_config.toml" ]]; do
    start_dir="$(dirname "$start_dir")"
  done

  if [[ -f "$start_dir/.kano/backlog_config.toml" ]]; then
    printf '%s\n' "$start_dir"
    return 0
  fi

  printf '%s\n' "$PWD"
}

WORKSPACE_ROOT="$(resolve_workspace_root)"

find_native_bin() {
  local exe_suffix=""
  local -a presets=(
    windows-ninja-msvc
    windows-ninja-clang
    windows-msbuild
    linux-ninja-clang
    linux-ninja-gcc
    macos-ninja-clang
    macos-ninja-clang-x64
    macos-ninja-clang-arm64
  )
  local -a configs=(debug release relwithdebinfo minsizerel)
  local preset
  local config
  local candidate

  case "$(uname -s 2>/dev/null || printf 'unknown')" in
    MINGW*|MSYS*|CYGWIN*) exe_suffix=".exe" ;;
  esac

  for preset in "${presets[@]}"; do
    for config in "${configs[@]}"; do
      candidate="$SKILL_ROOT/src/cpp/out/bin/$preset/$config/kano-backlog$exe_suffix"
      if [[ -f "$candidate" ]]; then
        printf '%s\n' "$candidate"
        return 0
      fi
    done

    candidate="$SKILL_ROOT/src/cpp/out/bin/$preset/kano-backlog$exe_suffix"
    if [[ -f "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

native_bin_matches_version() {
  local candidate="$1"
  local output=""
  local detected_version=""

  output="$($candidate --version 2>&1 || true)"
  detected_version="$(printf '%s\n' "$output" | grep -Eo '[0-9]+\.[0-9]+\.[0-9]+' | head -n 1 || true)"
  [[ -n "$detected_version" && "$detected_version" == "$EXPECTED_VERSION" ]]
}

NATIVE_BIN="$(find_native_bin || true)"

if [[ "${1-}" == "repo-hygiene" ]]; then
  NATIVE_BIN=""
fi

if [[ -n "$NATIVE_BIN" ]] && native_bin_matches_version "$NATIVE_BIN"; then
  cd "$WORKSPACE_ROOT"
  exec "$NATIVE_BIN" "$@"
fi

PYTHON_BIN="$(find_python_bin || true)"
if [[ -z "$PYTHON_BIN" ]]; then
  echo "Neither a native kano-backlog binary nor a Python interpreter was found." >&2
  echo "Build native with: bash scripts/internal/self-build.sh debug" >&2
  echo "Or run via Python after installing deps: python -m pip install -e \".[dev]\"" >&2
  exit 1
fi

cd "$WORKSPACE_ROOT"
MODULE_ROOT="$SKILL_ROOT/src/python"
case "$(uname -s 2>/dev/null || printf 'unknown')" in
  MINGW*|MSYS*|CYGWIN*)
    if command -v cygpath >/dev/null 2>&1; then
      MODULE_ROOT="$(cygpath -w "$MODULE_ROOT")"
    fi
    ;;
esac
exec "$PYTHON_BIN" -c "import sys; sys.path.insert(0, r'$MODULE_ROOT'); from kano_backlog_cli.cli import app; app(prog_name='kano-backlog')" "$@"
