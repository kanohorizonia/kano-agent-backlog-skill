{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentskill-backlog.kanohorizonia.com/references/evidence-quality-classification.schema.json",
  "title": "KOB Evidence Quality Classification",
  "type": "object",
  "required": ["schema", "claim_ref", "quality_state", "inputs", "human_wording", "fallback_behavior"],
  "properties": {
    "schema": { "const": "kob.evidence.quality_classification.v1" },
    "claim_ref": { "$ref": "#/$defs/ref" },
    "quality_state": {
      "enum": ["strong", "weak", "missing", "stale", "unclear", "contradicting"]
    },
    "inputs": {
      "type": "object",
      "properties": {
        "commits": { "type": "array", "items": { "type": "string" } },
        "validation": { "type": "array", "items": { "$ref": "#/$defs/ref" } },
        "artifacts": { "type": "array", "items": { "$ref": "#/$defs/ref" } },
        "worklogs": { "type": "array", "items": { "$ref": "#/$defs/ref" } },
        "dogfood": { "type": "array", "items": { "$ref": "#/$defs/ref" } },
        "falsifiers": { "type": "array", "items": { "$ref": "#/$defs/ref" } }
      },
      "additionalProperties": false
    },
    "human_wording": { "type": "string", "minLength": 1 },
    "fallback_behavior": { "type": "string", "minLength": 1 },
    "diagnostics": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "ref": {
      "type": "object",
      "required": ["product"],
      "properties": {
        "product": { "type": "string", "minLength": 1 },
        "item_id": { "type": "string" },
        "uid": { "type": "string" },
        "evidence_id": { "type": "string" },
        "artifact_id": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
