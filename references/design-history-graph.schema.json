{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentskill-backlog.kanohorizonia.com/references/design-history-graph.schema.json",
  "title": "KOB Design-History Graph",
  "type": "object",
  "required": ["schema", "product", "nodes", "edges", "diagnostics"],
  "properties": {
    "schema": { "const": "kob.product_memory.design_history_graph.v1" },
    "product": { "type": "string", "minLength": 1 },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    },
    "diagnostics": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "node_type", "title"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "node_type": {
          "enum": ["idea", "adr", "feature_event", "work_order", "evidence", "current_state"]
        },
        "title": { "type": "string" },
        "source_ref": { "$ref": "#/$defs/ref" }
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["from", "to", "edge_type"],
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "edge_type": {
          "enum": ["led_to", "rejected_by", "superseded_by", "validated_by", "invalidated_by", "implemented_by", "motivated_by"]
        },
        "source_ref": { "$ref": "#/$defs/ref" },
        "render_hint": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ref": {
      "type": "object",
      "required": ["product"],
      "properties": {
        "product": { "type": "string", "minLength": 1 },
        "item_id": { "type": "string" },
        "uid": { "type": "string" },
        "adr_id": { "type": "string" },
        "evidence_id": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
