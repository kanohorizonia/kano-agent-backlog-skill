{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentskill-backlog.kanohorizonia.com/references/adr-lifecycle-metadata.schema.json",
  "title": "KOB ADR Lifecycle Metadata",
  "type": "object",
  "required": ["schema", "adr_id", "decision_status", "feature_refs", "evidence_refs"],
  "properties": {
    "schema": { "const": "kob.product_memory.adr_lifecycle.v1" },
    "adr_id": { "type": "string", "minLength": 1 },
    "decision_status": {
      "enum": ["accepted", "rejected", "superseded", "revisit_needed", "stale"]
    },
    "feature_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/ref" }
    },
    "accepted_option": {
      "type": ["object", "null"],
      "properties": {
        "summary": { "type": "string" },
        "rationale": { "type": "string" }
      },
      "additionalProperties": false
    },
    "rejected_options": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["summary", "reason"],
        "properties": {
          "summary": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/ref" }
    },
    "superseded_by": {
      "type": "array",
      "items": { "$ref": "#/$defs/ref" }
    },
    "revisit_condition": {
      "type": ["object", "null"],
      "properties": {
        "summary": { "type": "string" },
        "evidence_ref": { "$ref": "#/$defs/ref" }
      },
      "additionalProperties": false
    },
    "diagnostics": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "ref": {
      "type": "object",
      "required": ["product"],
      "properties": {
        "product": { "type": "string", "minLength": 1 },
        "item_id": { "type": "string" },
        "uid": { "type": "string" },
        "adr_id": { "type": "string" },
        "evidence_id": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
