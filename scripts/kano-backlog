#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILL_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
WORKSPACE_ROOT="$(cd "$SKILL_ROOT/../../../.." && pwd)"
NATIVE_BIN="$SKILL_ROOT/src/cpp/build/windows-ninja-msvc/kano-backlog.exe"

if [[ ! -f "$NATIVE_BIN" ]]; then
  echo "Native CLI not found: $NATIVE_BIN" >&2
  echo "Build it first with: bash .agents/skills/kano/kano-agent-backlog-skill/scripts/internal/self-build.sh" >&2
  exit 1
fi

cd "$WORKSPACE_ROOT"
exec "$NATIVE_BIN" "$@"
